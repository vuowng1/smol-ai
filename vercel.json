{
  "version": 2,
  "builds": [
    {
      "src": "api/server.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "api/server.py"
    },
    {
      "source": "/(.*)",
      "destination": "public/$1"
    }
  ]
}
